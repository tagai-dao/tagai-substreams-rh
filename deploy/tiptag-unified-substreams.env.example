DATABASE_URL=postgres://tiptag@127.0.0.1:5433/tiptag_rh?sslmode=disable
SUBSTREAMS_ENDPOINT=robinhood.substreams.pinax.network:443
PACKAGE_PATH=/opt/tiptag-substreams/tiptag-unified-substreams-v0.1.0.spkg
# Set this to the common legacy/Basket cursor plus one at cutover time.
START_BLOCK=CHANGE_ME
STOP_BLOCK=
MODULE_HASH_MISMATCH_POLICY=error
CURSORS_TABLE=unified_cursors
HISTORY_TABLE=unified_substreams_history
