DATABASE_URL=postgres://tiptag:change-me@127.0.0.1:5432/tiptag_rh?sslmode=disable
SUBSTREAMS_ENDPOINT=robinhood.substreams.pinax.network:443
PACKAGE_PATH=/opt/tiptag-substreams/tiptag-substreams-v0.2.0.spkg
START_BLOCK=6922897
# Production follows the chain head, so STOP_BLOCK stays empty.
STOP_BLOCK=
# Keep strict in normal operation. Set to ignore only for a reviewed one-time
# cursor migration, then restore error immediately after the new hash is saved.
MODULE_HASH_MISMATCH_POLICY=error
